{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "types": ["node"],
    "noEmit": true,
    "noUncheckedIndexedAccess": true
  },
  "include": ["src/main.ts", "tests/**/*.ts", "playwright.config.ts"]
}
