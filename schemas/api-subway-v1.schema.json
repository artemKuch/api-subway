{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://api-subway.dev/schemas/api-subway-v1.schema.json",
  "title": "api-subway map v1",
  "description": "Stable intermediate representation emitted by api-subway v0.1.",
  "type": "object",
  "required": [
    "schema_version",
    "project",
    "endpoints",
    "dependencies",
    "relations",
    "diagnostics"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "project": { "$ref": "#/$defs/project" },
    "endpoints": {
      "type": "array",
      "maxItems": 10000,
      "items": { "$ref": "#/$defs/endpoint" }
    },
    "schemas": {
      "type": "array",
      "maxItems": 50000,
      "items": { "$ref": "#/$defs/apiSchema" }
    },
    "dependencies": {
      "type": "array",
      "maxItems": 10000,
      "items": { "$ref": "#/$defs/dependency" }
    },
    "relations": {
      "type": "array",
      "maxItems": 100000,
      "items": { "$ref": "#/$defs/relation" }
    },
    "diagnostics": {
      "type": "array",
      "maxItems": 50000,
      "items": { "$ref": "#/$defs/diagnostic" }
    }
  },
  "$defs": {
    "project": {
      "type": "object",
      "required": ["name", "root", "frameworks"],
      "properties": {
        "name": { "type": "string", "minLength": 1, "maxLength": 256 },
        "root": { "const": "." },
        "frameworks": {
          "type": "array",
          "maxItems": 8,
          "items": { "type": "string", "minLength": 1, "maxLength": 64 },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "endpoint": {
      "type": "object",
      "required": [
        "id",
        "method",
        "path",
        "display_path",
        "district",
        "framework"
      ],
      "properties": {
        "id": { "$ref": "#/$defs/endpointId" },
        "method": { "type": "string", "pattern": "^[A-Z]+$", "maxLength": 16 },
        "path": { "type": "string", "minLength": 1, "maxLength": 2048 },
        "display_path": { "type": "string", "minLength": 1, "maxLength": 2048 },
        "district": { "type": "string", "minLength": 1, "maxLength": 256 },
        "framework": { "type": "string", "minLength": 1, "maxLength": 64 },
        "operation_id": { "type": "string", "minLength": 1, "maxLength": 512 },
        "tags": {
          "type": "array",
          "maxItems": 1000,
          "items": { "type": "string", "minLength": 1, "maxLength": 256 },
          "uniqueItems": true
        },
        "sources": {
          "type": "array",
          "maxItems": 1000,
          "items": { "$ref": "#/$defs/source" }
        },
        "spec_only": { "type": "boolean" },
        "contract": { "$ref": "#/$defs/endpointContract" }
      },
      "additionalProperties": false
    },
    "endpointContract": {
      "type": "object",
      "required": ["confidence"],
      "properties": {
        "confidence": { "enum": ["inferred", "exact"] },
        "request": { "$ref": "#/$defs/requestContract" },
        "responses": {
          "type": "array",
          "maxItems": 1000,
          "items": { "$ref": "#/$defs/responseContract" }
        },
        "evidence": {
          "type": "array",
          "maxItems": 1000,
          "items": { "$ref": "#/$defs/evidence" }
        }
      },
      "additionalProperties": false
    },
    "requestContract": {
      "type": "object",
      "properties": {
        "parameters": {
          "type": "array",
          "maxItems": 1000,
          "items": { "$ref": "#/$defs/parameterContract" }
        },
        "bodies": {
          "type": "array",
          "maxItems": 1000,
          "items": { "$ref": "#/$defs/contentContract" }
        }
      },
      "additionalProperties": false
    },
    "parameterContract": {
      "type": "object",
      "required": ["name", "location", "required", "schema_id"],
      "properties": {
        "name": { "type": "string", "minLength": 1, "maxLength": 512 },
        "location": { "enum": ["path", "query", "header", "cookie"] },
        "required": { "type": "boolean" },
        "schema_id": { "$ref": "#/$defs/schemaId" }
      },
      "additionalProperties": false
    },
    "contentContract": {
      "type": "object",
      "required": ["media_type", "schema_id"],
      "properties": {
        "media_type": { "type": "string", "minLength": 1, "maxLength": 256 },
        "schema_id": { "$ref": "#/$defs/schemaId" },
        "required": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "responseContract": {
      "type": "object",
      "required": ["status"],
      "properties": {
        "status": {
          "type": "string",
          "pattern": "^(?:[1-5][0-9]{2}|[1-5]XX|default)$"
        },
        "contents": {
          "type": "array",
          "maxItems": 1000,
          "items": { "$ref": "#/$defs/contentContract" }
        }
      },
      "additionalProperties": false
    },
    "apiSchema": {
      "type": "object",
      "required": ["id", "kind", "confidence"],
      "properties": {
        "id": { "$ref": "#/$defs/schemaId" },
        "name": { "type": "string", "minLength": 1, "maxLength": 512 },
        "kind": {
          "enum": [
            "object",
            "array",
            "string",
            "integer",
            "number",
            "boolean",
            "null",
            "union",
            "intersection",
            "unknown"
          ]
        },
        "format": { "type": "string", "minLength": 1, "maxLength": 128 },
        "properties": {
          "type": "array",
          "maxItems": 1000,
          "items": { "$ref": "#/$defs/schemaProperty" }
        },
        "items": { "$ref": "#/$defs/schemaId" },
        "variants": {
          "type": "array",
          "maxItems": 1000,
          "items": { "$ref": "#/$defs/schemaId" },
          "uniqueItems": true
        },
        "enum_values": {
          "type": "array",
          "items": { "$ref": "#/$defs/schemaLiteral" },
          "maxItems": 1000
        },
        "const_value": { "$ref": "#/$defs/schemaLiteral" },
        "constraints": { "$ref": "#/$defs/schemaConstraints" },
        "nullable": { "type": "boolean" },
        "confidence": { "enum": ["inferred", "exact"] },
        "evidence": {
          "type": "array",
          "maxItems": 1000,
          "items": { "$ref": "#/$defs/evidence" }
        }
      },
      "additionalProperties": false
    },
    "schemaProperty": {
      "type": "object",
      "required": ["name", "schema_id", "required"],
      "properties": {
        "name": { "type": "string", "minLength": 1, "maxLength": 512 },
        "schema_id": { "$ref": "#/$defs/schemaId" },
        "required": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "schemaLiteral": {
      "type": "object",
      "required": ["kind", "value"],
      "properties": {
        "kind": { "enum": ["string", "integer", "number", "boolean", "null"] },
        "value": { "type": "string", "maxLength": 4096 }
      },
      "additionalProperties": false
    },
    "schemaConstraints": {
      "type": "object",
      "properties": {
        "min_length": { "type": "integer", "minimum": 0 },
        "max_length": { "type": "integer", "minimum": 0 },
        "minimum": { "type": "string", "pattern": "^-?[0-9]+(?:\\.[0-9]+)?$" },
        "maximum": { "type": "string", "pattern": "^-?[0-9]+(?:\\.[0-9]+)?$" },
        "min_items": { "type": "integer", "minimum": 0 },
        "max_items": { "type": "integer", "minimum": 0 },
        "pattern": { "type": "string", "maxLength": 256 }
      },
      "additionalProperties": false
    },
    "dependency": {
      "type": "object",
      "required": ["id", "name", "kind"],
      "properties": {
        "id": { "$ref": "#/$defs/dependencyId" },
        "name": { "type": "string", "minLength": 1, "maxLength": 512 },
        "kind": { "$ref": "#/$defs/dependencyKind" },
        "pinned": { "type": "boolean" },
        "packages": {
          "type": "array",
          "maxItems": 1000,
          "items": { "type": "string", "minLength": 1, "maxLength": 512 },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "relation": {
      "type": "object",
      "required": ["endpoint_id", "dependency_id", "confidence", "evidence"],
      "properties": {
        "endpoint_id": { "$ref": "#/$defs/endpointId" },
        "dependency_id": { "$ref": "#/$defs/dependencyId" },
        "confidence": { "enum": ["inferred", "exact"] },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "maxItems": 1000,
          "items": { "$ref": "#/$defs/evidence" }
        }
      },
      "additionalProperties": false
    },
    "evidence": {
      "type": "object",
      "required": ["kind", "detail"],
      "properties": {
        "kind": {
          "enum": [
            "framework",
            "call",
            "import",
            "configuration",
            "open-api",
            "heuristic"
          ]
        },
        "detail": { "type": "string", "minLength": 1, "maxLength": 4096 },
        "source": { "$ref": "#/$defs/source" }
      },
      "additionalProperties": false
    },
    "diagnostic": {
      "type": "object",
      "required": ["code", "severity", "message"],
      "properties": {
        "code": { "type": "string", "minLength": 1, "maxLength": 128 },
        "severity": { "enum": ["info", "warning", "error"] },
        "message": { "type": "string", "minLength": 1, "maxLength": 4096 },
        "source": { "$ref": "#/$defs/source" }
      },
      "additionalProperties": false
    },
    "source": {
      "type": "object",
      "required": ["file", "line", "column"],
      "properties": {
        "file": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4096,
          "not": { "pattern": "^(?:[A-Za-z]:[\\\\/]|/)" }
        },
        "line": { "type": "integer", "minimum": 1 },
        "column": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    },
    "endpointId": {
      "type": "string",
      "pattern": "^ep-[0-9a-f]{16}$"
    },
    "dependencyId": {
      "type": "string",
      "pattern": "^dep-[0-9a-f]{16}$"
    },
    "schemaId": {
      "type": "string",
      "pattern": "^schema-[0-9a-f]{16}$"
    },
    "dependencyKind": {
      "enum": ["middleware", "service", "datastore", "external"]
    }
  },
  "additionalProperties": false
}
